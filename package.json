{
  "name": "robopeer-v2",
  "module": "./src/main.ts",
  "type": "module",
  "scripts": {
    "start": "bun --bun run ./src/main.ts",
    "build": "bun --bun build ./src/main.ts --compile --outfile robopeer",
    "api:types": "openapi-typescript http://localhost:3000/docs/private/api.json -o ./src/lib/api/types.d.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "openapi-typescript": "6.7.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "http-parser-js": "^0.5.8",
    "openapi-fetch": "^0.8.2"
  }
}